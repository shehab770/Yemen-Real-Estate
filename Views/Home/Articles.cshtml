@model webProgramming.Models.ViewModels;
@{
    ViewData["Title"] = "NestHood-Articles";
    Layout = "_Mylayout";
    ViewData["MetaTitle"] = "NestHood-Articles";
    ViewData["MetaDescription"] = "NestHood-Articles";

    var pageSize = 4;
	var currentPage = Context.Request.Query["page"].ToString();
	var page = 1;
	if(!string.IsNullOrEmpty(currentPage))
	{
		page = int.Parse(currentPage);
	}
	var totalPages = (int)Math.Ceiling((Model.Articles?.Count() ?? 0) / (double)pageSize);
}

       <section class="flat-title " >
    <div class="container">
        <div class="row">                      
            <div class="col-lg-12">
                <div class="title-inner style">
                    <div class="title-group fs-12">
                        <a class="home fw-6 text-color-3" href="index.html">الرئيسية</a>
                        <span>المقالات</span>
                    </div>
                </div>
            </div> 
        </div>
    </div>
</section>
            
<section class="tf-section2 flat-blog-grid flat-property style3" >
    <div class="container">
        <div class="row flex">                      
            <div class="col-lg-8">
                <div class="post">
                    <div class="category-filter flex  justify-space">
                        <div class="box-1 ">
                            <div class="heading-listing fs-30 lh-45 fw-7">المقالات</div>
                        </div>
                    </div>
                    <div class="flat-blog">
                        <div class="wrap-blog form-wg flex flex-wrap">
                            @if(Model.Articles != null)
                            {
                                @foreach(var item in Model.Articles.Skip((page-1) * pageSize).Take(pageSize))
                                {
                                   <div class="box hover-img wg-box">
                                        <div class="images img-style relative ">
                                            <img style="width: 350px; height: 251px;" src="@item.Image" alt="images">
                                            <div class="sub-box flex align-center fs-13 fw-6">
                                                <div class="title-1">@item.CreatedAt.ToString("MMM")</div>
                                                <a class="title-2 text-color-3">@item.HouseType</a>
                                            </div>
                                        </div>
                                        <div class="content center">
                                            <h3><a href="/Home/ArticleDetail/@item.Id">@item.Title</a></h3>
                                            <div class="meta">
                                                <a href="/Home/ArticleDetail/@item.Id" class="btn-button flex align-center justify-center fs-13 fw-6 text-color-3">
                                                    <span>اقرأ المزيد</span> 
                                                    <svg width="13" height="12" viewBox="0 0 13 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M0.875 6H12.125M12.125 6L7.0625 0.9375M12.125 6L7.0625 11.0625" stroke="#FFA920" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </svg> 
                                                </a>
                                            </div>
                                        </div>
                                    </div> 
                                }
                            }
                        </div>
                    </div>

                    <div class="themesflat-pagination clearfix center">
                        <ul>
                            @if(page > 1)
                            {
                                <li><a href="?page=@(page-1)" class="page-numbers style"><i class="far fa-angle-left"></i></a></li>
                            }
                            @for(int i = 1; i <= totalPages; i++)
                            {
                                if(i == page)
                                {
                                    <li><a href="?page=@i" class="page-numbers current">@i</a></li>
                                }
                                else
                                {
                                    <li><a href="?page=@i" class="page-numbers">@i</a></li>
                                }
                            }
                            @if(page < totalPages)
                            {
                                <li><a href="?page=@(page+1)" class="page-numbers style"><i class="far fa-angle-right"></i></a></li>
                            }
                        </ul>
                    </div> 
                 </div>
                </div>  
                <div class="col-lg-4">
                    <aside class="side-bar side-bar-1 side-blog">
                        <div class="inner-side-bar">  
                            <div class="widget widget-listings style"> 
                                <h3 class="widget-title title-list">
                                    مقالات ذات صلة
                                </h3>                                                                                                                        
                                @if(Model.Articles != null)
                                {
                                    @foreach(var item in Model.Articles)
                                    {
                                         <div class="box-listings flex hover-img3">
                                            <div class="img-listings img-style3">
                                                <img style="width: 112px; height: 80px;" src="@item.Image" alt="images">
                                            </div>
                                            <div class="content link-style-1">
                                                <a class="fs-16 lh-24" href="/Home/ArticleDetail/@item.Id">@item.Title</a>
                                                <h4>عدد المشاهدات: @item.ViewsCount</h4>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </aside>
                </div>
             
            </div>
        </div>
    </div>
</section>