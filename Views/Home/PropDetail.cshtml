@model webProgramming.Models.ViewModels

@using Newtonsoft.Json;

@{
    var product = Model.Product;
    var properties = JsonConvert.DeserializeObject<dynamic>(product?.Properties ?? "Property Details");
    var listingImages = JsonConvert.DeserializeObject<dynamic>(product?.ListingImages ?? "[]");
    var propTitle = product?.Title;

    ViewData["Title"] = propTitle ?? "Property Details";
    Layout = "_MyLayout";
}

<section class="flat-title ">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="title-inner style-detail">
                    <div class="title-group fs-12"><a class="home fw-6 text-color-3" href="index.html">Home</a><span>@(product.Title ?? "Property Details")</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="flat-slider01">
    <div class="container-full">
        <div class="row">
            <div class="col-lg-12">
                <div class="swiper-container thumbs-swiper-column">
                    <div class="swiper-wrapper">
                            @if(listingImages != null)
                            {
                                foreach(var image in listingImages)
                                {
                                     <div class="swiper-slide">
                                        <div class="image-detail">
                                            <img style="width: 100%; height: 624px;" src="@image" alt="images">
                                        </div>
                                    </div>
                                }
                            }
                    </div>

                    <div class="button-custom-slider">
                        <div class="swiper-button-next5"><i class="far fa-chevron-down"></i></div>
                        <div class="swiper-button-prev5"><i class="far fa-chevron-up"></i></div>
                    </div>

                </div>

                <div thumbsSlider="" class="swiper-container thumbs-swiper-column1 swiper-pagination5">
                    <div class="swiper-wrapper">
                        @if(listingImages != null)
                        {
                           foreach(var image in listingImages)
                           {
                             <div class="swiper-slide">
                                <div class="image-detail">
                                    <img style="width: 71px; height: 71px;" src="@image" alt="images">
                                </div>
                            </div>
                           }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if(product != null)
{
    <section class="flat-property-detail style2">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">

                        <div class="wrap-house wg-dream flex bg-white">
                            <div class="box-1">
                                <div class="title-heading fs-30 fw-7 lh-45">@propTitle</div>
                                <div class="inner flex">
                                    <div class="sales fs-12 fw-7 font-2 text-color-1">For @product.Type</div>
                                    <div class="text-address"><p>@product.Address</p></div>
                                    <div class="icon-inner flex">
                                        <div class="years-icon flex align-center">
                                            <i class="fal fa-calendar"></i>
                                            <p class="text-color-2">@product.YearBuilt</p>
                                        </div>
                                        <div class="view-icon flex align-center">
                                            <i class="far fa-heart"></i>
                                            <p class="text-color-2">@product.FavorCount Liked it</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="icon-box flex">
                                    <div class="icons icon-1 flex"><span>Beds: </span><span class="fw-6">@properties?.bedrooms_num</span></div>
                                    <div class="icons icon-3 flex"><span>Sqft: </span><span class="fw-6">@properties?.bedrooms_size</span></div>
                                    <div class="icons icon-2 flex"><span>Baths: </span><span class="fw-6">@properties?.bathrooms_num</span></div>
                                    <div class="icons icon-3 flex"><span>Sqft: </span><span class="fw-6">@properties?.bathrooms_size</span></div>
                                    @if(product.Type == PropertyType.Rent)
                                    {
                                        <div class="icons icon-3 flex"><span>Rent Duration: </span><span class="fw-6">@product.CategoryType</span></div>
                                    }
                                </div>
                            </div>
                            <div class="box-2 text-end">
                                <div class="icon-boxs flex">
                                    <button class="btn favorite-btn" onclick="toggleFavorite('@product.ProductId')" id="favorite-@product.ProductId" style="background-color: transparent; border: none;">
                                        <i class="@(Model.Favors?.FirstOrDefault(f => f.ProductId == product.ProductId && f.UserId == Model.User?.UserId) != null ? "fas" : "far") fa-heart" style="cursor: pointer; font-size: 22px; transition: all 0.3s ease; color: #4CAF50; filter: drop-shadow(0 2px 3px rgba(0,0,0,0.2));"></i>
                                    </button>
                                </div>
                                <div class="moneys fs-30 fw-7 lh-45 text-color-3">$@product.Price</div>
                                <div class="text-sq fs-12 lh-16">@properties?.prop_size Sq Ft</div>
                            </div>
                        </div>
                </div>
            </div>
        </div>

        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <div class="post">
                        <div class="wrap-overview wrap-style">
