                                                <div class="icon-box flex">
                                                    <div class="icons icon-1 flex"><span>Beds: </span>@trait?["bedrooms_num"]<span
                                                            class="fw-6">4</span></div>
                                                    <div class="icons icon-2 flex"><span>Baths:  </span>@trait?["bathrooms_num"]<span
                                                            class="fw-6">2</span></div>
                                                    <div class="icons icon-3 flex"><span>Sqft: </span><span
                                                            class="fw-6">@trait?["prop_size"]</span></div>
                                                </div>
                                                <div class="days-box flex justify-space align-center">
                                                    <a class="compare flex align-center fw-6" href="#">@(Model.Seller?.Name ?? "NestHood")</a>
                                                    <div class="img-author hv-tool" data-tooltip="Kathryn Murphy"><img
                                                            src="@(Model.Seller?.Image ?? "~assets/images/author/author-31.jpg")" alt="images"></div>
                                                    <div class="days">@item.YearBuilt</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<partial name="_ContactPartial" />

@* Partial View *@
@section Scripts{
   @* js for toggling the favorite icon without refreshing the page *@
    <script>
        function toggleFavorite(productId) {
            $.ajax({
                url: '/Home/ToggleFavorite',
                type: 'POST',
                data: { productId: productId },
                success: function(response) {
                    if (response.success) {
                        // Update icon immediately before showing alert
                        const icon = $(`#favorite-${productId} i`);
                        if (response.isFavorited) {
                            icon.removeClass('far').addClass('fas');
                        } else {
                            icon.removeClass('fas').addClass('far'); 
                        }
                        
                        Swal.fire({
                            title: response.title,
                            text: response.message,
                            icon: response.icon || 'success',
                            allowOutsideClick: true,
                            backdrop: true,
                            showConfirmButton: true,
                            confirmButtonText: 'OK'
                        });
                    } else {
                        Swal.fire({
                            title: response.title || 'Authentication Required',
                            text: response.message || 'Please login to add favorites',
                            icon: response.icon || 'warning',
                            allowOutsideClick: true,
                            backdrop: true,
                            showConfirmButton: true,
                            confirmButtonText: 'OK'
                        });
                    }
                },
                error: function() {
                    Swal.fire({
                        title: 'Error',
                        text: 'An error occurred while updating favorites',
                        icon: 'error',
                        allowOutsideClick: true,
                        backdrop: true,
                        showConfirmButton: true,
                        confirmButtonText: 'OK'
                    });
                }
            });
        }
    </script> 
}