@model webProgramming.Models.ViewModels
@using Newtonsoft.Json
@{
    ViewData["Title"] = "بدء محادثة جديدة";
    Layout = "Admin_Layout";
}

<aside style="left:0;" class="main-sidebar sidebar-dark-primary elevation-4">
    <!-- Brand Logo -->
    <a href="/@(Model.User?.Role == UserRole.Buyer ? "Customer" : "Seller")/Index" class="brand-link">
        <img src="@Model.User?.Image" alt="AdminLTE Logo" class="brand-image img-circle elevation-3"
             style="opacity: .8">
        <span class="brand-text font-weight-light">@Model.User?.Name </span>
    </a>

    <!-- Sidebar -->
    <Partial name="_AgnetDahboardPartial" /> 
    <!-- /.sidebar -->
</aside>

<!-- Main content -->
<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">Start New Chat</h1>
                </div>
            </div>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Select Agent and Property</h3>
                        </div>
                        @if(TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger">
                                @TempData["ErrorMessage"]
                            </div>
                        }
                        <div class="card-body">
                            <form action="/Chat/StoreChat" method="POST" id="createChatForm">
                                <input type="hidden" name="BuyerId" value="@Model.User?.UserId" />

                                <div class="form-group mb-4">
                                    <label class="form-label">Select an Agent</label>
                                    @if (Model.Seller != null)
                                    {
                                        <div class="agent-card p-3 border rounded mb-2 selected" 
                                             data-seller-id="@Model.Seller.UserId">
                                            <div class="d-flex align-items-center">
                                                <img src="@Model.Seller.Image" alt="@Model.Seller.Name" 
                                                     class="rounded-circle mr-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                <div>
                                                    <h5 class="mb-1">@Model.Seller.Name</h5>
                                                </div>
                                            </div>
                                        </div>
                                        <input type="hidden" name="SellerId" id="selectedSellerId" value="@Model.Seller.UserId" />
                                    }
                                </div>

                                <div class="form-group mb-4">
                                    <div class="property-list mt-3" style="max-height: 300px; overflow-y: auto;">
                                        @if (Model.Product != null)
                                        {
                                            var productJson = JsonConvert.DeserializeObject<dynamic>(Model.Product.Properties);
                                            <div class="property-card p-3 border rounded mb-2 selected" 
                                                 data-product-id="@Model.Product.ProductId">
                                                <div class="row">
                                                    <div class="col-md-4">
                                                        <img src="@Model.Product.MainImage" alt="@productJson?.prop_title" class="img-fluid">
                                                    </div>
                                                    <div class="col-md-8">
                                                        <h5 class="mb-1">@productJson?.prop_title</h5>
                                                        <p class="mb-1">$@productJson?.prop_price.</p>
                                                        <small class="text-muted">@Model.Product.Address</small>
                                                    </div>
                                                </div>
                                            </div>
                                            <input type="hidden" name="ProductId" id="selectedProductId" value="@Model.Product.ProductId" />
                                        }
                                    </div>
                                </div>

                                <div class="form-group mb-4">
                                    <label class="form-label">Type your message</label>
                                    <textarea class="form-control" name="content" rows="4" 
                                            placeholder="Type your message to the seller here..."
                                            required></textarea>
                                </div>

                                <div class="text-right">
                                    <button type="submit" class="btn btn-primary" id="startChatBtn">
                                        Start Chat
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    .agent-card, .property-card {
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .agent-card:hover, .property-card:hover {
        background-color: #f8f9fa;
        transform: translateY(-2px);
    }

    .agent-card.selected, .property-card.selected {
        background-color: #e3f2fd;
        border-color: #2196f3 !important;
    }

    .property-card img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 4px;
    }

    .cursor-pointer {
        cursor: pointer;
    }
</style>

